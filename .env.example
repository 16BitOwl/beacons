# Cloudflare
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_A_ID=your-zone-id
CF_ZONE_B_ID=your-zone-id

# Pi-hole
PIHOLE_URL=https://pihole.example.com
PIHOLE_PASSWORD=your-pihole-password
